    "start": "node dist/server.js",
    "seed": "ts-node-esm src/scripts/seed.ts"
  },
  "dependencies": {
    "express": "^4.18.0",
    "mongoose": "^7.7.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.6.0"
  }
}
